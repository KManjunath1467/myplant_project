# MyPlant Backend - Environment Variables Template
# Copy this file to .env and fill in your actual values

# ======================================
# Database Configuration
# ======================================
DB_URL=jdbc:mysql://localhost:3306/myplant?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=

# ======================================
# JWT Configuration
# ======================================
JWT_SECRET=MyPlantSecretKey1234567890123456789012345678901234567890
JWT_EXPIRATION=86400000

# ======================================
# Email Configuration
# ======================================
# Using Gmail as SMTP server
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@myplant.com

# Get your Gmail app password:
# 1. Go to https://myaccount.google.com/
# 2. Select "Security" on the left
# 3. Enable "2-Step Verification"
# 4. Generate "App password" for "Mail" and "Windows Computer"

# ======================================
# OpenWeatherMap API
# ======================================
# Get free API key from: https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=YOUR_API_KEY_HERE
OPENWEATHERMAP_API_URL=https://api.openweathermap.org/data/2.5/weather

# ======================================
# Twilio Configuration (for WhatsApp)
# ======================================
# Get credentials from: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=YOUR_ACCOUNT_SID
TWILIO_AUTH_TOKEN=YOUR_AUTH_TOKEN
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ======================================
# Server Configuration
# ======================================
SERVER_PORT=8080
PROFILE=dev
